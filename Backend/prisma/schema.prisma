generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  fullName     String
  email        String    @unique
  phone        String?
  password     String?
  userType     String    @default("Homeowner")
  role         String    @default("user")
  profileImage String?
  company      String?
  bio          String?
  googleId     String?   @unique
  isVerified   Boolean   @default(false)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projects     Project[]
  generations  AIGeneration[]
  subscription Subscription?
  payments     Payment[]
  downloads    Download[]

  @@map("users")
}

model Project {
  id          String   @id @default(uuid())
  userId      String
  name        String
  roomType    String?
  style       String?
  length      Float?
  width       Float?
  height      Float?
  floorType   String?
  ceilingType String?
  assets      String[]
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  uploads     RoomUpload[]
  generations AIGeneration[]
  downloads   Download[]

  @@map("projects")
}

model RoomUpload {
  id           String   @id @default(uuid())
  projectId    String
  originalUrl  String
  cloudinaryId String?
  analyzedData Json?
  createdAt    DateTime @default(now())

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("room_uploads")
}

model AIGeneration {
  id           String   @id @default(uuid())
  projectId    String
  userId       String
  outputType   String
  prompt       String?  @db.Text
  outputUrl    String?
  cloudinaryId String?
  status       String   @default("pending")
  creditsUsed  Int      @default(1)
  provider     String?
  errorMessage String?
  createdAt    DateTime @default(now())

  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  downloads    Download[]

  @@map("ai_generations")
}

model Subscription {
  id           String    @id @default(uuid())
  userId       String    @unique
  planName     String    @default("free")
  totalCredits Int       @default(3)
  usedCredits  Int       @default(0)
  status       String    @default("active")
  startedAt    DateTime  @default(now())
  expiresAt    DateTime?
  gatewaySubId String?

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments     Payment[]

  @@map("subscriptions")
}

model Payment {
  id             String   @id @default(uuid())
  userId         String
  subscriptionId String?
  gateway        String
  amount         Float
  currency       String   @default("INR")
  status         String   @default("pending")
  transactionId  String?
  orderId        String?
  createdAt      DateTime @default(now())

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

  @@map("payments")
}

model Download {
  id           String   @id @default(uuid())
  userId       String
  projectId    String?
  generationId String?
  fileUrl      String
  fileType     String
  fileSize     String?
  createdAt    DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id])
  generation   AIGeneration? @relation(fields: [generationId], references: [id])

  @@map("downloads")
}
